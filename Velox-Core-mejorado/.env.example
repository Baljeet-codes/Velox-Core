# ── Base de datos ─────────────────────────────────────────────
DATABASE_URL=postgresql://ecommerce_user:ecommerce123@127.0.0.1:5433/ecommerce_db

# ── JWT ───────────────────────────────────────────────────────
# Genera uno seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-este-secreto-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── AWS S3 (opcional — dejar vacío para usar almacenamiento local) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
